[[workflows.workflow]]
name = "QR Legends Syntax Fixed"
author = 44464284
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f \"python.*main.py\" || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"🔍 Checking syntax...\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m py_compile main.py"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"✅ Syntax check passed\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"🚀 Starting QR Legends...\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

