
<?xml version='1.0' encoding='utf-8'?>
<widget id="com.qrlegends.warehouse" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>QR Legends</name>
    <description>
        Professional warehouse inventory management with QR code scanning
    </description>
    <author email="support@qrlegends.com" href="https://qrlegends.com">
        QR Legends Team
    </author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    
    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
        <preference name="CameraUsesGeolocation" value="false" />
        <icon src="www/img/icon.png" width="57" height="57" />
        <icon src="www/img/icon@2x.png" width="114" height="114" />
    </platform>
    
    <platform name="android">
        <allow-intent href="market:*" />
        <icon src="www/img/icon.png" density="mdpi" />
        <icon src="www/img/icon.png" density="hdpi" />
    </platform>
    
    <plugin name="cordova-plugin-camera" spec="^6.0.0" />
    <plugin name="cordova-plugin-file" spec="^7.0.0" />
    <plugin name="cordova-plugin-device" spec="^2.1.0" />
    <plugin name="cordova-plugin-whitelist" spec="^1.3.5" />
    <plugin name="cordova-plugin-inappbrowser" spec="^5.0.0" />
</widget>
